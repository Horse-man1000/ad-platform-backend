# Server
PORT=3000
CORS_ORIGINS="http://localhost:5173,http://localhost:3001,http://localhost:3000"

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/adplatform?schema=public"

# 32-byte key recommended for token encryption workflows
ENCRYPTION_KEY="CHANGE_ME_TO_A_32_CHAR_VALUE"

# OAuth placeholders (future use)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/auth/google/callback"
META_CLIENT_ID=""
META_CLIENT_SECRET=""
META_REDIRECT_URI="http://localhost:3000/auth/meta/callback"
